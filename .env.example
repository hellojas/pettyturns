# Async multiplayer (Firebase / Firestore) — see FIREBASE_SETUP.md
#
# All VITE_FIREBASE_* values default to the pettyturns project baked into
# src/imperium/net/firebaseConfig.ts (Firebase web keys are public project
# identifiers, not secrets — access is enforced by firestore.rules). Copy this
# file to .env.local only if you need to override them or point at another
# project.

# Set to false to disable Firebase and play async against the local mock only.
VITE_USE_FIREBASE=true

# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
